# Auth mode:
#   "basic"    - backend "local" profile, HTTP Basic (development)
#   "db"       - backend "db-auth" profile, login against the application database (POST /api/auth/login, JWT)
#   "keycloak" - backend "prod" profile, redirect login via Keycloak (JWT)
VITE_AUTH_MODE=db

# Keycloak settings (used only when VITE_AUTH_MODE=keycloak)
VITE_KEYCLOAK_URL=http://localhost:8081
VITE_KEYCLOAK_REALM=ncrm
VITE_KEYCLOAK_CLIENT_ID=ncrm-frontend
